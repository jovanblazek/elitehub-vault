NODE_ENV=development
PORT=3000
LOG_LEVEL=info
API_KEY_SECRET_PEPPER=replace-with-a-long-random-secret

SENTRY_DSN_API=
SENTRY_DSN_EDDN_WORKER=
SENTRY_DSN_EDDN_LISTENER=
SENTRY_RELEASE=

# Postgres
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB_NAME=vault
POSTGRES_CONNECTION_STRING=postgresql://admin:password@localhost:5432/vault

# Redis
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=password
REDIS_HOST=127.0.0.1
