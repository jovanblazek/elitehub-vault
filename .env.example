NODE_ENV=development
PORT=3000
LOG_LEVEL=info

SENTRY_DSN_API=
SENTRY_DSN_EDDN_WORKER=
SENTRY_DSN_EDDN_LISTENER=

# Postgres
POSTGRES_PORT=5432
