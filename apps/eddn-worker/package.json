    "@sentry/node": "^10.32.1",
    "@t3-oss/env-core": "^0.13.11",
    "bullmq": "^5.58.5",
    "drizzle-orm": "0.45.1",
    "drizzle-zod": "0.8.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@elitehub/typescript-config": "workspace:*",
    "tsx": "^4.21.0"
