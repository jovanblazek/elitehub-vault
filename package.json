{
  "name": "elitehub-vault",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@elitehub/api...",
    "dev:eddn-listener": "turbo run dev --filter=@elitehub/eddn-listener...",
    "dev:eddn-worker": "turbo run dev --filter=@elitehub/eddn-worker...",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{js,ts,tsx,json,css,md,yml,yaml}\"",
    "drizzle:generate": "pnpm --dir packages/db drizzle:generate",
    "drizzle:migrate": "pnpm --dir packages/db drizzle:migrate",
    "drizzle:studio": "pnpm --dir packages/db drizzle:studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "keywords": [],
  "author": "jovanblazek",
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/koa": "^3.0.0",
    "@types/koa-bodyparser": "^4.3.13",
    "@types/koa-ratelimit": "^5.0.5",
    "@types/node": "^24.3.1",
    "@types/pg": "^8.15.5",
    "oxlint": "^1.31.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "turbo": "^2.9.3"
  },
  "engines": {
    "node": "^22.14.0"
  },
  "packageManager": "pnpm@9.15.9"
}
