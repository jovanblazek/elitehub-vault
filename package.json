{
  "name": "elitehub-vault",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@elitehub/api...",
    "dev:eddn-listener": "turbo run dev --filter=@elitehub/eddn-listener...",
    "dev:eddn-worker": "turbo run dev --filter=@elitehub/eddn-worker...",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "release": "semantic-release",
    "format": "prettier --write \"**/*.{js,ts,tsx,json,css,md,yml,yaml}\"",
    "drizzle:generate": "pnpm --dir packages/db drizzle:generate",
    "drizzle:migrate": "pnpm --dir packages/db drizzle:migrate",
    "drizzle:studio": "pnpm --dir packages/db drizzle:studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "keywords": [],
  "author": "jovanblazek",
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/koa": "3.0.2",
    "@types/koa-bodyparser": "4.3.13",
    "@types/node": "22.19.7",
    "@types/pg": "8.20.0",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/exec": "7.1.0",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.6",
    "@semantic-release/release-notes-generator": "14.1.0",
    "oxlint": "1.62.0",
    "prettier": "3.8.3",
    "semantic-release": "25.0.3",
    "tsconfig-paths": "4.2.0",
    "turbo": "2.9.7",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": "^22.14.0"
  },
  "packageManager": "pnpm@9.15.9"
}
