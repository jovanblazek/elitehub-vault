{
  "name": "elitehub-vault",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts --tsconfig ./tsconfig.json",
    "build": "tsc",
    "start": "node --import ./dist/utils/sentry.js dist/index.js",
    "debug:sse": "tsx src/scripts/debugSse.ts",
    "test": "NODE_ENV=test node --import tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "prettier --write \"**/*.{js,ts,tsx,css,md}\"",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:migrate": "drizzle-kit migrate",
    "drizzle:studio": "drizzle-kit studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "scripts:recreate-migrations-table": "tsx src/scripts/recreateMigrationsTable.ts"
  },
  "keywords": [],
  "author": "jovanblazek",
  "license": "GPL-3.0",
  "dependencies": {
    "@escape.tech/graphql-armor": "^3.2.0",
    "@graphile/simplify-inflection": "8.0.0-rc.2",
    "@haathie/postgraphile-otel": "^0.1.0",
    "@haathie/postgraphile-reasonable-limits": "0.2.0",
    "@sentry/node": "^10.32.1",
    "bullmq": "^5.58.5",
    "dotenv": "^17.2.2",
    "drizzle-orm": "0.45.1",
    "drizzle-zod": "0.8.3",
    "ioredis": "^5.7.0",
    "koa": "^3.0.1",
    "koa-bodyparser": "^4.4.1",
    "koa-ratelimit": "^6.0.0",
    "pg": "^8.16.3",
    "pino": "^9.9.4",
    "pino-pretty": "^13.1.1",
    "postgraphile": "5.0.0-rc.3",
    "zeromq": "^6.5.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/koa": "^3.0.0",
    "@types/koa-bodyparser": "^4.3.13",
    "@types/koa-ratelimit": "^5.0.5",
    "@types/node": "^24.3.1",
    "@types/pg": "^8.15.5",
    "drizzle-kit": "0.31.8",
    "oxlint": "^1.31.0",
    "prettier": "^3.6.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.5",
    "turbo": "^2.9.3",
    "typescript": "^5.9.2"
