    "db:recreate-migrations-table": "tsx src/scripts/recreateMigrationsTable.ts"
  },
  "dependencies": {
    "dotenv": "^17.2.2",
    "drizzle-orm": "0.45.1"
  },
  "devDependencies": {
    "@elitehub/typescript-config": "workspace:*",
    "drizzle-kit": "0.31.8",
    "tsx": "^4.20.5"
