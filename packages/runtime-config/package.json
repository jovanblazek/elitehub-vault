{
  "name": "@elitehub/runtime-config",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sentry": {
      "types": "./dist/sentry.d.ts",
      "import": "./dist/sentry.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "oxlint src"
  },
  "dependencies": {
    "@sentry/node": "10.51.0",
    "@t3-oss/env-core": "0.13.11",
    "dotenv": "17.4.2",
    "ioredis": "5.10.1",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "zod": "4.4.1"
  },
  "devDependencies": {
    "@elitehub/typescript-config": "workspace:*"
  }
}
