{
  "name": "@elitehub/runtime-config",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sentry": {
      "types": "./dist/sentry.d.ts",
      "import": "./dist/sentry.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "oxlint src"
  },
  "dependencies": {
    "@sentry/node": "^10.32.1",
    "@t3-oss/env-core": "^0.13.11",
    "dotenv": "^17.2.2",
    "ioredis": "^5.7.0",
    "pino": "^9.9.4",
    "pino-pretty": "^13.1.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@elitehub/typescript-config": "workspace:*"
  }
}
